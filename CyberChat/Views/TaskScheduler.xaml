<Window x:Class="CyberChat.TaskScheduler"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberChat"
        mc:Ignorable="d"
        Title="CyberChat Task Scheduler Engine" Height="650" Width="480"
        WindowStartupLocation="CenterOwner" Background="#F4F4F5">
    <Window.Resources>
 
        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#005B99"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>

        <Style x:Key="FormInput" TargetType="Control">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>

        <!-- Context menu shared resource for data views -->
        <ContextMenu x:Key="SharedTaskContextMenu">
            <MenuItem Header="Delete Task" Click="deleteContxtMenu"/>
            <MenuItem Header="Mark as Complete" Click="deleteContxtMenu"/>
        </ContextMenu>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Row 0: Text Inputs -->
            <RowDefinition Height="Auto" />
            <!-- Row 1: Time Pickers -->
            <RowDefinition Height="Auto" />
            <!-- Row 2: Operation Buttons -->
            <RowDefinition Height="*" />
            <!-- Row 3: Live Output Monitors -->
        </Grid.RowDefinitions>

        <!-- SECTION 1: FORM INPUT ENTRY FIELDS -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🛡️ Task Scheduler &amp; Alert Engine" Style="{StaticResource HeaderLabel}"/>

            <TextBlock Text="Task Title:" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TitleBox" Style="{StaticResource FormInput}" Padding="4,2"/>

            <TextBlock Text="Task Description Details:" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="DescriptionBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Padding="4,2"/>
        </StackPanel>

        <!-- SECTION 2: DATE & TIME CONFIGURATION INPUTS -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Target Date:" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                <DatePicker x:Name="TargetDatePicker" Style="{StaticResource FormInput}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                <TextBlock Text="Hour (00-23):" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                <ComboBox x:Name="ComboHours" Style="{StaticResource FormInput}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Minute (00-59):" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                <ComboBox x:Name="ComboMinutes" Style="{StaticResource FormInput}"/>
            </StackPanel>
        </Grid>

        <!-- SECTION 3: SYSTEM CONTROL ACTION BUTTONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,15">
            <Button x:Name="btnSaveTask" Click="SafeTask" Content="💾 Save Task" Width="90" Style="{StaticResource ActionButton}"/>
            <Button x:Name="btnSetReminder" Click="SetReminderButton_Click" Content="🔔 Set Reminder" Width="105" Style="{StaticResource ActionButton}" Background="#005B99" Foreground="White" FontWeight="SemiBold"/>
            <Button x:Name="btnViewTasks" Click="ViewTasksButton_Click" Content="🔍 View Tasks" Width="95" Style="{StaticResource ActionButton}"/>
            </StackPanel>

            <!-- SECTION 4: LIVE MONITOR DISPLAY LOG GRIDS -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Active Workspace Tasks List View -->
            <ListBox x:Name="listBoxArea" ItemsSource="{Binding TasksGrid}" Margin="0,0,0,10" Grid.Row="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="ContextMenu" Value="{StaticResource SharedTaskContextMenu}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Relational Database Log DataGrid View -->
            <DataGrid x:Name="datagridtasks" AutoGenerateColumns="True" Grid.Row="1" Background="White" AlternatingRowBackground="#F9F9FB" ContextMenu="{StaticResource SharedTaskContextMenu}" />
        </Grid>
    </Grid>

</Window>
