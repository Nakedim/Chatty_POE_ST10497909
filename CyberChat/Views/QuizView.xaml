<UserControl x:Class="CyberChat.Views.QuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="DarkCyan"
             BorderThickness="2"
             d:DesignWidth="800"
             Height="348">

    <Grid>

        <TextBlock x:Name="QuestionTextBlock"
                   HorizontalAlignment="Left"
                   Margin="83,94,0,0"
                   VerticalAlignment="Top"
                   Width="551"
                   Height="140"
                   Background="Cyan"
                   TextWrapping="Wrap"
                   Text="What does CPU stand for?" />

        <TextBox x:Name="AnswerTextBox"
                 HorizontalAlignment="Left"
                 Margin="83,239,0,0"
                 VerticalAlignment="Top"
                 Width="551"
                 Height="41" />

        <Button Content="Submit"
                HorizontalAlignment="Left"
                Margin="83,308,0,0"
                VerticalAlignment="Top"
                Width="98"
                Click="Submit_Click"/>

        <Button Content="Clear"
                HorizontalAlignment="Left"
                Margin="209,308,0,0"
                VerticalAlignment="Top"
                Width="98"
                Click="Clear_Click"/>
        <Button Content="Exit Quiz"
            HorizontalAlignment="Left"
            Margin="325,308,0,0"
            VerticalAlignment="Top"
            Width="98"
            Click="CancelGame_click"/>

    </Grid>
</UserControl>