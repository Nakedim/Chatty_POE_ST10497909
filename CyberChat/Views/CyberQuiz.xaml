<UserControl x:Class="CyberChat.Views.CyberQuiz"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CyberChat.Views"
             mc:Ignorable="d" 
             d:DesignWidth="800"
             Background="DarkCyan"
             BorderThickness="2"
             
             Height="475"
             >

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Question Counter & Score -->
            <RowDefinition Height="*"/>
            <!-- Question Panel -->
            <RowDefinition Height="Auto"/>
            <!-- Feedback panel -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons Row -->
        </Grid.RowDefinitions>

        <!-- Top Header Progress and Score Grid Row 0 -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="10,0,10,10">
            <TextBlock x:Name="ProgressTextBlock" Text="Question -- of --" Foreground="White" FontSize="14" FontWeight="Bold" DockPanel.Dock="Left"/>
            <TextBlock x:Name="ScoreTextBlock" Text="Score: 0" Foreground="White" FontSize="14" FontWeight="Bold" DockPanel.Dock="Right"/>
        </DockPanel>
        <!-- Main Quiz Presentation Container Grid Row 1 -->
        <StackPanel Grid.Row="1" Margin="10,0,10,10">
            <TextBlock x:Name="QuestionTextBlock"
                       Background="Cyan"
                       Foreground="Black"
                       TextWrapping="Wrap"
                       Padding="10"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="Question text will appear here..." 
                       Height="70"/>

            <!-- Dynamic Options Container (Handles both True/False & Multi-Choice) -->
            <StackPanel x:Name="OptionsPanel" Margin="0,15,0,0">
                <!-- Radio buttons will be automatically injected here by code-behind -->
            </StackPanel>
        </StackPanel>
        <Border Grid.Row="2" x:Name="FeedbackPanel" Background="#E0F7FA" CornerRadius="4" Padding="12" Margin="10,5,10,15" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="FeedbackResultText" FontWeight="Bold" FontSize="15" Foreground="Black" Text="Grading Result Placeholder"/>
                <TextBlock x:Name="ExplanationText" TextWrapping="Wrap" Foreground="Black" FontSize="13" Margin="0,6,0,0" Text="Explanation details go here..."/>
            </StackPanel>
        </Border>
        <!-- Action Control Navigation Buttons Grid Row 3 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
            <!-- Submit Button (Hidden after clicked) -->
            <Button x:Name="SubmitButton" 
                    Content="Submit" 
                    Width="98" 
                    Height="28" 
                    Margin="0,0,10,0" 
                    Click="Submit_Click"/>

            <!-- Next Button (Becomes visible only after submitting an answer) -->
            <Button x:Name="NextButton" 
                    Content="Next" 
                    Width="98" 
                    Height="28" 
                    Margin="0,0,10,0" 
                    Click="Next_Click" 
                    Visibility="Collapsed"/>

            <!-- Exit Quiz Button -->
            <Button Content="Exit Quiz" 
                    Width="98" 
                    Height="28" 
                    Margin="0,0,10,0" 
                    Click="CancelGame_click"/>

            <!-- Back to Chat Button -->
            <Button Content="Back To Chat" 
                    Width="98" 
                    Height="28" 
                    Click="ReturnToMain"/>
        </StackPanel>
    </Grid>
</UserControl>
