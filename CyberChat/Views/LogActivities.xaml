<Page x:Class="CyberChat.Views.LogActivities"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CyberChat.Views"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="600"
      Title="LogActivities" Background="Cyan" >

    <Grid Background="#F4F4F4" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Main Header -->
            <RowDefinition Height="*"/>
            <!-- 1: App Actions List -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Chat History Subheader -->
            <RowDefinition Height="*"/>
            <!-- 3: Chat History List -->
            <RowDefinition Height="Auto"/>
            <!-- 4: Footer Button Area -->
        </Grid.RowDefinitions>

        <!-- 1. Main Header Area -->
        <TextBlock Grid.Row="0" 
                   Text="System Activity Logs" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="#333333" 
                   Margin="0,0,0,10"/>

        <!-- 2. Application Actions Log Display Area -->
        <ListBox x:Name="LogArea_AppActions" 
                 Grid.Row="1"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Padding="10"
                 Background="White"
                 Foreground="Green"
                 BorderBrush="#CCCCCC"
                 BorderThickness="1"
                 FontSize="14"
                 FontFamily="Consolas" 
                 Margin="0,0,0,15"/>

        <!-- 3. Chat History Section Divider -->
        <TextBlock Grid.Row="2" 
                   Text="Chat History Only"
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="#333333" 
                   Margin="0,0,0,10"/>

        <!-- 4. Database Log Display Area -->
        <ListBox x:Name="LogArea" 
                 Grid.Row="3"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Padding="10"
                 Background="White"
                 BorderBrush="#CCCCCC"
                 BorderThickness="1"
                 FontSize="14"
                 FontFamily="Consolas" 
                 Margin="0,0,0,15"/>

        <!-- 5. Footer Area -->
        <Grid Grid.Row="4">
            <Button Content="Back to Chat Room" 
                    Width="160" 
                    Height="40" 
                    HorizontalAlignment="Right" 
                    FontSize="13" 
                    FontWeight="SemiBold"
                    Click="BackBtn_Click"/>
        </Grid>
    </Grid>
</Page>
