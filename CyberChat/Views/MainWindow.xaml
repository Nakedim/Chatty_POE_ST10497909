<Window x:Class="CyberChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberChatBot"
        Height="750"
        Background="Cyan"
        Width="780">
    <DockPanel>

        <!-- Top Menu Layer -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New Task" Click="NewTask_click"/>
                <MenuItem Header="Play Quiz" Click="quizGame_click"/>
                <Separator />
                <MenuItem Header="Log">
                    <MenuItem Header="View Activity log..."/>
                </MenuItem>
                <Separator />
                <MenuItem Header="Exit" Click="exit_click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <!-- 1. MAIN CHAT INTERFACE REGION -->
            <Grid x:Name="ChatInterfaceGrid" Margin="10,10,10,24" Height="703" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="60" />
                </Grid.RowDefinitions>

                <!-- Chat Log View -->
                <ListBox Name="ChatBotArea"
                         Grid.Row="0"
                         FontSize="16" 
                         Margin="10,192,10,58">
                </ListBox>

                <!-- Branding Elements -->
                <StackPanel Margin="0,151,0,99">
                    <TextBlock Name="AppLogo" HorizontalAlignment="Left" Margin="180,-150,0,0" 
                               TextWrapping="Wrap" VerticalAlignment="Top" Height="110" Width="495"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,90,0,133"/>

                <!-- Messaging Input Forms -->
                <TextBox x:Name="MsgInput"
                         Text="Type your message here..."
                         KeyDown="MsgInput_KeyDown"
                         Foreground="Gray"
                         GotFocus="AnimateCursorGotFocus"
                         LostFocus="AnimateCursorLostFocus" 
                         Margin="10,580,117,0" />

                <Button x:Name="Send"
                        Content="Send"
                        Click="Send_Click" 
                        Margin="613,580,10,0"/>

                <!-- Quick Feature Navigation Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0, 120">
                    <Button Content="Task Scheduler" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="45" Width="94" Click="TaskBtn_Click"/>
                    <Button Content="Play Quiz" Name="QuizBtn" Click="quizGame_click" HorizontalAlignment="Left" Margin="60,3,0,0" VerticalAlignment="Top" Height="45" Width="94"/>
                </StackPanel>

                <Button Content="Activity Log" HorizontalAlignment="Left" Margin="307,124,0,0" VerticalAlignment="Top" Height="44" Width="73"/>
            </Grid>

            <!-- 2. SUBWINDOW DYNAMIC CONTAINER REGION -->
            <!-- This starts hidden and hosts your quiz view when called -->
            <ContentControl x:Name="SubWindowContainer" Margin="10" Visibility="Collapsed"/>
        </Grid>
    </DockPanel>
</Window>
