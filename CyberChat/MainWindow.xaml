<Window x:Class="CyberChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberChatBot"
        Height="650"
        Background="Cyan"
        Width="650">

    <Grid Margin="10,10,10,54">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <!-- logo Area -->

        <!-- Chat Area -->
        <ListBox Name="ChatBotArea"
                 Grid.Row="0"
                 FontSize="16" Margin="0,151,0,99"/>

        <!-- Bottom Input Area -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal" Margin="0,10,0,10" Grid.RowSpan="2">


        </StackPanel>
        <StackPanel Margin="0,151,0,99">
            <TextBlock Name="AppLogo" HorizontalAlignment="Left" Margin="65,-133,0,0" 
                      
                       TextWrapping="Wrap"
                       VerticalAlignment="Top" Height="110" Width="495"/>
        </StackPanel>
        <ScrollViewer Name="ScrollViewer" 
                      Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      Margin="0,0,0,10">
            
        </ScrollViewer>

        <StackPanel Orientation="Horizontal" Margin="0,125,0,99"/>
        <TextBox x:Name="MsgInput"
                     Text="Type your message here..."
                     KeyDown ="MsgInput_KeyDown"
                     Foreground="Gray"
                     GotFocus="AnimateCursorGotFocus"
                     LostFocus="AnimateCursorLostFocus" Margin="0,390,130,58" />
        <Button x:Name="Send"
                    Content="Send"
                    Click="Send_Click" Margin="500,390,0,58"/>
        <Label Content="Label" HorizontalAlignment="Left" Margin="10,457,0,0" VerticalAlignment="Top" Height="39" Width="73"/>




    </Grid>
</Window>