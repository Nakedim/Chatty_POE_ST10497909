<Window x:Class="CyberChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberChatBot"
        Height="500"
        Width="650">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <!-- logo Area -->

        <!-- Chat Area -->
        <ListBox Name="ChatBotArea"
                 Grid.Row="0"
                 FontSize="16" Margin="0,151,0,0"/>

        <!-- Bottom Input Area -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal">

            <!-- User Input -->
            <TextBox Name="MessageInput"
                     Width="500"
                     Height="40"
                     Margin="0,0,10,0" KeyDown ="MessageInput_TextChanged"/>

            <!-- Send Button -->
            <Button Name="Send"
                    Content="Send"
                    Width="100"
                    Height="40"
                    Click="Send_Click"/>

        </StackPanel>
        <Grid>
            <TextBlock Name="AppLogo" HorizontalAlignment="Left" Margin="56,26,0,0" TextWrapping="Wrap"
                       Text="" VerticalAlignment="Top" Height="95" Width="410"/>
        </Grid>



    </Grid>
</Window>