<Window x:Class="CyberChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberChatBot"
        Height="650"
        Width="650">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <!-- logo Area -->

        <!-- Chat Area -->
        <ListBox Name="ChatBotArea"
                 Grid.Row="0"
                 FontSize="16" Margin="0,151,0,99"/>

        <!-- Bottom Input Area -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal" Margin="0,10,0,10" Grid.RowSpan="2">

            <!-- User Input -->
            <TextBox Name="MsgInput"
                     Width="500"
                     Height="35"
                     Margin="0,0,10,0"
                     Text="Type your message here..."
                     KeyDown ="MsgInput_KeyDown"
                     Foreground="Gray"
                     GotFocus="AnimateCursorGotFocus"
                     LostFocus="AnimateCursorLostFocus" />

            <!-- Send Button -->
            <Button Name="Send"
                    Content="Send"
                    Width="100"
                    Height="40"
                    Click="Send_Click"/>



        </StackPanel>
        <StackPanel Margin="0,0,0,99">

        </StackPanel>
        <Grid Margin="0,-78,0,82">
            <TextBlock Name="AppLogo" HorizontalAlignment="Left" Margin="56,75,0,0" TextWrapping="Wrap"
                       Text="" VerticalAlignment="Top" Height="95" Width="410"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,99"/>
      
        <TextBox HorizontalAlignment="Center" 
                 Name="BotQuestionText"
                 Margin="0,486,0,0" TextWrapping="Wrap"
                 Text="TextBox" VerticalAlignment="Top"
                 Foreground="white"
                 Background="Black"
                 Width="610" Height="58"/>




    </Grid>
</Window>