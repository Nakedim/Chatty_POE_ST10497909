<Window x:Class="CyberChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberChatBot"
        Height="650"
        Background="Cyan"
        Width="650">

    <Grid Margin="10,10,10,7">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <!-- logo Area -->

        <!-- Chat Area -->
        <ListBox Name="ChatBotArea"
                 Grid.Row="0"
                 FontSize="16" Margin="0,151,0,99"/>

        <!-- Bottom Input Area -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal" Margin="0,10,0,10" Grid.RowSpan="2">

            <!-- User Input -->

            <!-- Send Button -->
            <!-- User Input -->

            <!-- Send Button -->
            <!-- User Input -->

            <!-- Send Button -->
            <!-- User Input -->

            <!-- Send Button -->
            <!-- User Input -->
            <TextBox x:Name="MsgInput"
                     Width="500"
                     Height="36"
                     Text="Type your message here..."
                     KeyDown ="MsgInput_KeyDown"
                     Foreground="Gray"
                     GotFocus="AnimateCursorGotFocus"
                     LostFocus="AnimateCursorLostFocus" />

            <!-- Send Button -->
            <Button x:Name="Send"
                    Content="Send"
                    Width="130"
                    Height="35"
                    Click="Send_Click"/>



        </StackPanel>
        <StackPanel Margin="0,151,0,99">
            <TextBlock Name="AppLogo" HorizontalAlignment="Left" Margin="65,-133,0,0" 
                      
                       TextWrapping="Wrap"
                       VerticalAlignment="Top" Height="110" Width="495"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,125,0,67"/>




    </Grid>
</Window>