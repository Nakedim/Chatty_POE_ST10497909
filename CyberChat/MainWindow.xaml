<Window x:Class="CyberChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberChat"
        mc:Ignorable="d"
        Title="CyberChatBot" Height="900" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Canvas></Canvas>

        <ListBox Name="ChatBotArea"
                 Margin="0,115,10,554"
                 Grid.Row="0"
                 FontSize="16"
                 
                 />

        <StackPanel Orientation="Horizontal" Margin="0,287,0,477">
            <!--
             TextBlock
            -->
            <TextBlock Name="MessageBox"
                       Width="300"
                       Height="50"
                       Margin="0,0,10,0"
                       />

            <!--
   button
  -->
            <Button Name="Send"
                    Content="Send"
                    Width="90"
                    Click="Send_Click">

            </Button>
            <TextBlock x:Name="botArea"
                       Width="300"
                       Height="50"
                       
                       />


        </StackPanel>

    </Grid>

</Window>
