<UserControl x:Class="CyberChat.DateTimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CyberChat"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="250">
    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Column 0: Visual Calendar Component -->
            <StackPanel Grid.Column0>
                <TextBlock Text="1. Select Date" FontWeight="Bold" Margin="0,0,0,5" Foreground="#333333"/>
                <Calendar x:Name="InnerCalendar" SelectedDatesChanged="OnSelectedDateChanged"/>
            </StackPanel>

            <!-- Column 2: Time Selection Fields -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="2. Select Time" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333333"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <!-- Hours Spinner -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Hour" FontSize="11" Foreground="#666666"/>
                        <ComboBox x:Name="HoursCombo" Width="60" SelectionChanged="OnTimeChanged"/>
                    </StackPanel>

                    <!-- Minutes Spinner -->
                    <StackPanel>
                        <TextBlock Text="Minute" FontSize="11" Foreground="#666666"/>
                        <ComboBox x:Name="MinutesCombo" Width="60" SelectionChanged="OnTimeChanged"/>
                    </StackPanel>
                </StackPanel>

                <!-- Clean Summary Output -->
                <TextBlock Text="Selected Target:" FontSize="11" Foreground="#666666"/>
                <TextBlock x:Name="TxtSummary" Text="No date selected" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Border>
    
</UserControl>
