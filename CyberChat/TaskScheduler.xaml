<Window x:Class="CyberChat.TaskScheduler"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberChat"
        mc:Ignorable="d"
        Title="TaskScheduler" Height="330" Width="437">
    <Grid Margin="20,34,20,45">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="143*"/>
            <ColumnDefinition Width="32*"/>
            <ColumnDefinition Width="585*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />



        </Grid.RowDefinitions>
        <TextBlock HorizontalAlignment="Left" Margin="10,30,0,0" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Height="31" Width="415" FontWeight="Bold" Grid.ColumnSpan="3"><Run Language="en-za" Text="Title"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="10,75,0,0" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Height="19" Width="376" FontWeight="Bold" Grid.ColumnSpan="3"><Run Language="en-za" Text="Description"/></TextBlock>
        <CheckBox  HorizontalAlignment="Left" Margin="55,206,0,0" Grid.Row="6" VerticalAlignment="Top" Checked="CheckBox_Checked" RenderTransformOrigin="0.501,0.378"/>
        <TextBox HorizontalAlignment="Left" Margin="10,46,0,0" Grid.Row="6" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="376" Height="24" Grid.ColumnSpan="3"/>
        <TextBox HorizontalAlignment="Left" Margin="10,99,0,0" Grid.Row="6" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="376" Height="54" Grid.ColumnSpan="3"/>
        <Button Content="Save Task" HorizontalAlignment="Left" Margin="128,158,0,0" Grid.Row="6" VerticalAlignment="Top" Height="26" Width="70" Grid.ColumnSpan="3"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,189,0,0" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Height="31" Width="365" Grid.ColumnSpan="3" ><Run Text="Do you wan to set reminder for ta"/><Run Text="s"/><Run Text="ks"/><Run Language="en-za" Text=", Tick the box to agree or leave it blank"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="10,-2,0,0" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Height="31" Width="365" Grid.ColumnSpan="3" ><Run Language="en-za" Text="Save your task below and set a reminder (Optional)"/></TextBlock>

    </Grid>
</Window>
