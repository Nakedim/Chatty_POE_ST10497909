<Window x:Class="CyberChat.TaskScheduler"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberChat"
        mc:Ignorable="d"
        Title="TaskScheduler" Height="502" Width="470">
    <Grid Margin="20,34,10,13">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />



        </Grid.RowDefinitions>
        <TextBlock HorizontalAlignment="Left" Margin="14,19,0,0" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Height="22" Width="416" FontWeight="Bold"><Run Language="en-za" Text="Title"/></TextBlock>

        <TextBlock HorizontalAlignment="Left" Margin="15,75,0,0" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Height="19" Width="414" FontWeight="Bold"><Run Language="en-za" Text="Description"/></TextBlock>

        <TextBox Name="TitleBox" HorizontalAlignment="Center" Margin="0,46,0,0" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Width="414" Height="24"/>
        <TextBox Name ="DescriptionBox" HorizontalAlignment="Center" Margin="0,99,0,0" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Width="414" Height="95"/>


        <Button Click ="SetReminderBtn_Click"  Content="Set Reminder" HorizontalAlignment="Left" Margin="122,210,0,0" Grid.Row="6" VerticalAlignment="Top" Height="26" Width="82"  RenderTransformOrigin="0.306,0.13"/>
        <Button Click ="SafeTask" Content="Save Task" HorizontalAlignment="Left" Margin="10,210,0,0" Grid.Row="6" VerticalAlignment="Top" Height="26" Width="90"  RenderTransformOrigin="0.494,0.54"/>


        <!--<ListBox Name="listBoxArea" Grid.Row="6" Grid.ColumnSpan="3" Margin="2,261,6,15"/>-->
        <ListBox Grid.Row="6" 
                 Name="ListBoxArea"
                 d:ItemsSource="{d:SampleData ItemCount=5}" 
                 Margin="0,245,2,77"/>
        <CheckBox Name="reminderBox" Content="CheckBox" HorizontalAlignment="Left" Margin="358,215,0,0" Grid.Row="6" VerticalAlignment="Top"/>
        <Button Content="View Tasks" HorizontalAlignment="Left" Margin="219,210,0,0" Grid.Row="6" VerticalAlignment="Top" Height="26" Width="93" Click="btnLoad_Click"/>
        <Button Grid.Column="1" Content="Button" HorizontalAlignment="Left" Margin="49,223,0,0" Grid.Row="6" VerticalAlignment="Top" Width="0"/>
        <Button Content="Delete Task" HorizontalAlignment="Left" Margin="10,367,0,0" Grid.Row="6" VerticalAlignment="Top" Height="31" Width="71" Click="DeleteTasks"/>


    </Grid>
</Window>
